from __future__ import annotations

import pytest

from {{MODULE}} import {{CLASS_NAME}}

@pytest.mark.asyncio
async def test_admin_modes_switch() -> None:
    app = {{CLASS_NAME}}()
    async with app.run_test(size=(100, 30)) as pilot:
        await pilot.press("2")
        await pilot.pause()
        assert app.current_mode == "jobs"
